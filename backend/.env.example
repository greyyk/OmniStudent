# Copy to .env and edit. The real .env is gitignored.
#
# SQLite, zero setup:
# DATABASE_URL=sqlite:///./omnistudent.db
#
# PostgreSQL, local development:
# DATABASE_URL=postgresql+psycopg://omnistudent:omnistudent@localhost:5432/omnistudent
#
DATABASE_URL=sqlite:///./omnistudent.db
SECRET_KEY=dev-secret-change-in-production
FRONTEND_ORIGIN=http://localhost:5173
